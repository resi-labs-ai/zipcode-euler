# CRE secrets manifest (template). Copy to secrets.yaml (gitignored) and populate.
# The scaffold reads ONE secret on the DON runtime (§8.10: DON-only — raw secret material must never
# enter a consensus observation). The read is fail-safe and illustrative; the workflow proceeds without it.
#
# The `id` here must match cfg.SecretId in your workflow config. The raw value is supplied out-of-band
# (env var / 1Password ref via .env), never committed here.
secretsNames:
  DEMO_SECRET:
    - CRE_DEMO_SECRET
