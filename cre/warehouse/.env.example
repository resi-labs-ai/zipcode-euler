# cre-warehouse env (template). Copy to .env (gitignored) and fill in.
#
# CRE-04 needs NO live secret for the build (K6) — the §8.5/§8.9 mock warehouse-op event arrives via the http
# trigger payload. These vars are for the cre-cli deploy/run flow (target profile + signer), not for the
# workflow logic.

# The cre-cli target profile (matches a stanza in project.yaml).
CRE_TARGET=local-simulation

# The workflow-owner signing key (or a 1Password ref). NEVER commit the raw value.
# NOTE (§8.5): the warehouse adapter uses a DISTINCT Forwarder identity / workflowId from the
# controller/registry/oracle receivers — deploy this workflow under its own owner/workflow identity.
CRE_ETH_PRIVATE_KEY=

# ── Workflow Config (the JSON passed via cre.ParseJSON[Config]) — documented here for convenience ──
# chainSelector   : the chain hosting the WarehouseAdminModule receiver
# warehouse       : the WarehouseAdminModule address (§17 — re-pointable, never hardcoded)
# writeGasLimit   : WriteReport gas limit (0 falls back to 600000)
# authorizedKeys  : optional http.Config authorized keys (empty for the build)
