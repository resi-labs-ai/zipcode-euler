# KEEPER-00 — keeper service config. Copy to .env and fill in. .env is gitignored.
# NOTHING here is a real secret; the key below is the public anvil dev key.

# --- operator hot key (NEVER committed; never logged) ---
# Primary path: 0x-hex 32-byte private key.
# anvil dev key (account #3) — replace for any real network.
KEEPER_OPERATOR_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
# Secondary (documented) path: a geth keystore file instead of the hex key.
# KEEPER_KEYSTORE_FILE=/path/to/keystore.json
# KEEPER_KEYSTORE_PASSWORD=changeme

# --- chain / RPC ---
KEEPER_RPC_URL=http://127.0.0.1:8545
KEEPER_CHAIN_ID=8453

# --- scalar knobs (defaults applied if unset; explicit 0 is rejected) ---
KEEPER_POLL_INTERVAL=30s
KEEPER_GAS_BUFFER_BPS=3000      # gas LIMIT buffer in bps; 3000 => x1.30 (limit only, not the fee cap)
KEEPER_FEE_CAP_MULTIPLIER=2     # base-fee headroom: maxFee = baseFee*MULT + tip
KEEPER_CONFIRM_TIMEOUT=60s

# --- BurnJob floor (KEEPER-01a) ---
# Minimum engine-Safe szipUSD balance to trigger a burnFor (base-10, env-only).
# 0 IS allowed here (= burn any non-zero fill) — unlike the scalar knobs above,
# whose explicit 0 is rejected. Default 0 if unset.
KEEPER_MIN_BURN_AMOUNT=0

# --- StrikeLoopJob knobs (KEEPER-01b; TUNABLE / C4) ---
# bps knobs must be in (0,10000]; an explicit 0 is rejected (like GAS_BUFFER_BPS).
KEEPER_CUSHION_BPS=200            # slippage/min-floor cushion (200 = 2%)
KEEPER_AMBER_FRACTION_BPS=5000    # taper fraction in the amber band (5000 = 50%)
KEEPER_RECYCLE_FRACTION_BPS=10000 # fraction of the floor surplus to recycle (10000 = all)
KEEPER_HALT_PRICE_USDC=15000      # halt below this HYDX price (USDC 6dp; 15000 = $0.015)
KEEPER_AMBER_PRICE_USDC=18000     # taper below this HYDX price (USDC 6dp; 18000 = $0.018)
KEEPER_DEADLINE_BUFFER=300s       # exercise/sell deadline = now + this
KEEPER_TWAP_PERIOD=3600s          # ICHI TWAP window for ZipToShares minShares
# REQUIRED for the StrikeLoopJob (no default — bounds per-cycle exposure). USDC 6dp.
KEEPER_MAX_BORROW_PER_CYCLE=1000000000000  # 1,000,000 USDC

# --- WindDownLpJob knobs (KEEPER-02; exception-only, disarmed by default) ---
# Arm the wind-down LP-dissolution job (unstake → removeLiquidity). "true"/"1" ⇒ on.
# Default off — wind-down is exception/directive-driven, never a routine poll.
KEEPER_WINDDOWN_ENABLED=false
# Protected/private RPC for the wind-down removeLiquidity broadcast (Base-supporting).
# Only Private actions' SendTransaction routes here; reads/nonce/fees/receipt stay on
# KEEPER_RPC_URL. Empty ⇒ no private routing (txs broadcast on the PUBLIC mempool —
# the keeper warns at startup if wind-down is armed without it).
KEEPER_PRIVATE_RPC_URL=
# Optional per-invocation share cap (base-10), defense-in-depth on top of the
# coverage-excess clamp. 0 = no cap (an explicit 0 is valid). Default 0.
KEEPER_WINDDOWN_MAX_SLICE=0
# Spot↔TWAP deviation ceiling (bps) for the wind-down withdraw floor. Above it the
# pool is treated as manipulated/volatile and the job no-ops. Must be in (0,10000];
# default 100 (1%, mirrors the ICHI deposit hysteresis).
KEEPER_WINDDOWN_MAX_DEVIATION_BPS=100

# --- address book (re-pointable, §17): KEEPER_ADDR_<NAME>=0x... ---
# Only the names a registered job references must be set. The StrikeLoopJob needs
# the six engine modules + the HYDX/USDC pool; the LP vault's pool is read off the
# vault (LpStrategyModule.ichiVault().pool()), so no separate pool config.
KEEPER_ADDR_ExitGate=0xd9b8393fD5057bcb4Fb2d86a1FD594fD8Ebae89e
KEEPER_ADDR_HarvestVoteModule=0x0000000000000000000000000000000000000A01
KEEPER_ADDR_FarmUtilityLoopModule=0x61cdc9c8839753f520cc9dc4f2a733e132fe10e4
KEEPER_ADDR_ExerciseModule=0x0000000000000000000000000000000000000A03
KEEPER_ADDR_SellModule=0x0000000000000000000000000000000000000A04
KEEPER_ADDR_RecycleModule=0x0000000000000000000000000000000000000A05
KEEPER_ADDR_LpStrategyModule=0x0000000000000000000000000000000000000A06
KEEPER_ADDR_HydxUsdcPool=0x51f0B932855986B0E621c9D4DB6Eee1f4644D3D2
# Registered for KEEPER-01, not called this window (MAY be absent/zero):
KEEPER_ADDR_ZipRedemptionQueue=0x46c89c1a4e86b7F025871c35F08aA7DA95F79D8f

# --- optional JSON file overlay (env wins over file) ---
# KEEPER_CONFIG_FILE=/path/to/keeper.json
